{
    "swagger": "2.0",
    "info": {
        "title": "API EXAMPLE",
        "contact": {},
        "version": "1.0"
    },
    "basePath": "/",
    "paths": {
        "/example": {
            "get": {
                "security": [
                    {
                        "Auth": []
                    }
                ],
                "description": "Retorna a lista de exemplos cadastrados.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Example"
                ],
                "summary": "Listar exemplos",
                "responses": {
                    "200": {
                        "description": "Lista de exemplos",
                        "schema": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            }
                        }
                    },
                    "500": {
                        "description": "Erro interno",
                        "schema": {
                            "$ref": "#/definitions/response.responseError"
                        }
                    }
                }
            }
        },
        "/health": {
            "get": {
                "description": "Retorna um status \"Ok!\" se a aplicação estiver rodando corretamente.",
                "produces": [
                    "text/plain"
                ],
                "tags": [
                    "Health"
                ],
                "summary": "Verifica a saúde da aplicação.",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/response.response"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "response.response": {
            "type": "object",
            "properties": {
                "message": {
                    "type": "string"
                }
            }
        },
        "response.responseError": {
            "type": "object",
            "properties": {
                "details": {
                    "type": "object",
                    "additionalProperties": {
                        "type": "string"
                    }
                },
                "message": {
                    "type": "string"
                }
            }
        }
    },
    "securityDefinitions": {
        "Auth": {
            "description": "Digite \"Bearer\" seguido de um espaço e o token JWT. Exemplo: \"Bearer eyJhbGci...\"",
            "type": "apiKey",
            "name": "Authorization",
            "in": "header"
        }
    }
}